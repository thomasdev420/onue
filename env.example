# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Amply public version (navbar label, GET /api/v1/status, OpenAPI info.version)
NEXT_PUBLIC_AMPLY_PRODUCT_VERSION=3.1.12

# NextAuth Configuration
NEXTAUTH_SECRET=your_nextauth_secret_key
NEXTAUTH_URL=https://your-production-domain.com

# Google OAuth (Optional for development)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OpenAI Configuration (app code uses this name — not OPENAI_API_KEYS)
OPENAI_API_KEY=your_openai_api_key

# TikTok API Configuration (Optional)
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=https://your-production-domain.com/api/auth/tiktok/callback

# File Upload Limits
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_MAX_VIDEO_SIZE=104857600

# Feature Flags
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=false
NEXT_PUBLIC_ENABLE_AI_PROMPTS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# Performance Settings
NEXT_PUBLIC_DEBOUNCE_DELAY=1000

# Database Configuration (if using external database)
DATABASE_URL=your_database_url

# Amply v1 API (routing)
# Comma-separated API keys; when set, POST /api/v1/route requires Authorization: Bearer (env key OR user key from dashboard)
AMPLY_API_KEYS=
# When 1, anonymous POST /api/v1/route is rejected unless a valid user key is configured (use with dashboard keys)
# AMPLY_REQUIRE_API_KEY=1
# Server-side fetch helper: app/lib/amplyRoute/serverPostAmplyRoute.js
# AMPLY_ROUTE_SERVER_KEY=
# AMPLY_ROUTE_API_BASE=https://www.useamply.com
# Scripts (smoke:v1-route, verify:deploy): AMPLY_ROUTE_BEARER_TOKEN or AMPLY_DEV_ROUTE_TOKEN if not using AMPLY_API_KEYS
# Per-user keys: Supabase + run database_setup_amply_api_keys.sql (dashboard → API keys)
AMPLY_V1_RATE_LIMIT_PER_MIN=120
# GET /api/v1/status diagnostics: catalog_metrics_stale when metrics_as_of is older than this (hours)
# AMPLY_CATALOG_STALE_AFTER_HOURS=24

# Vercel Cron: GET /api/cron/catalog-refresh — Vercel sends Authorization: Bearer <CRON_SECRET>
# Generate: openssl rand -hex 24
# CRON_SECRET=

# verify:deploy — exit 1 when catalog stale (optional CI gate)
# AMPLY_VERIFY_FAIL_ON_STALE=1

# Postgres pool for catalog reads (when DATABASE_URL is set)
# AMPLY_PG_POOL_MAX=3
# AMPLY_PG_CONN_TIMEOUT_MS=12000
# AMPLY_PG_IDLE_MS=20000

# In-process cache for successful Postgres catalog load (per warm serverless instance). 0 = disable.
# AMPLY_CATALOG_CACHE_MS=20000

# Logs: JSON lines to stdout (default). Set to 0 for plain console in dev.
# AMPLY_LOG_STRUCTURED=1

# Provider funnel: optional Calendly for “List your service” (see ProviderJoinForm)
# NEXT_PUBLIC_CALENDLY_PROVIDER_URL=https://calendly.com/your-org/provider

# Optional Stripe Payment Links (Payment Links → copy https://buy.stripe.com/... URL)
# NEXT_PUBLIC_STRIPE_LISTING_BASIC_URL=
# NEXT_PUBLIC_STRIPE_LISTING_FEATURED_URL=
# NEXT_PUBLIC_STRIPE_LISTING_SPOTLIGHT_URL=

# Synthetic probe (scripts/synthetic-probe.mjs): pass URL as arg or set this (otherwise script exits with usage)
# AMPLY_PROD_URL=https://www.useamply.com
# AMPLY_PROBE_ITERATIONS, AMPLY_PROBE_FAIL_COMPUTE_P95_MS, AMPLY_PROBE_FAIL_WALL_P95_MS (optional gate; wall is sensitive to runner↔edge RTT)

# Security
JWT_SECRET=your_jwt_secret_key
ENCRYPTION_KEY=your_encryption_key

# External Services (Optional)
CLOUDINARY_URL=your_cloudinary_url
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=your_aws_region
AWS_S3_BUCKET=your_s3_bucket_name 