# Copy to .env locally. On Vercel: Settings → Environment Variables (no quotes, no space after =).

# --- Amply v1 routing + Supabase catalog ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_OR_legacy_anon_jwt
SUPABASE_SERVICE_ROLE_KEY=sb_secret_OR_legacy_service_role_jwt

# Recommended on Vercel: direct Postgres connection (reads catalog via TCP; avoids PostgREST fetch issues).
# Supabase → Project Settings → Database → Connection string → URI (use "Transaction" pooler for serverless).
# Password with special characters must be percent-encoded in the URI, or use Supabase's copy-paste string as-is.
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# Aliases also work: POSTGRES_URL, POSTGRES_PRISMA_URL, SUPABASE_DB_URL (first non-empty wins).

# --- POST /api/v1/route auth (pick one style; do not put a key hash in AMPLY_API_KEYS — use raw secrets only) ---
#
# A) Server / emergency keys — comma-separated. If set, Bearer must match one of these OR a valid user key in amply_api_keys.
# AMPLY_API_KEYS=key_one,key_two
#
# B) User-key-only (no server keys): leave AMPLY_API_KEYS unset and require a Bearer on every request (DB validates amply_sk_…).
# AMPLY_REQUIRE_API_KEY=1
#
# Scripts (smoke:v1-route, verify:deploy) need a Bearer for POST when prod requires auth. Use either:
# AMPLY_API_KEYS=...   OR a single user key:
# AMPLY_ROUTE_BEARER_TOKEN=amply_sk_...
# (alias: AMPLY_DEV_ROUTE_TOKEN)
#
# Server-side calls from your Next app (Route Handlers / Server Actions): never expose the key to the browser.
# AMPLY_ROUTE_SERVER_KEY=amply_sk_..._or_server_key
# AMPLY_ROUTE_API_BASE=https://www.useamply.com
#
# POST /api/v1/route — max requests per minute per IP (per serverless instance). Unset or 0 = disabled.
# For global limits add Vercel Firewall / Upstash. Example:
# AMPLY_V1_RATE_LIMIT_PER_MIN=120

# Vercel Production: set NEXT_PUBLIC_SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY (validates user API keys), and DATABASE_URL
# (same Postgres URI as Supabase) so catalog reads work. Redeploy after changing env.
#
# After deploy, from repo root:
#   npm run verify:deploy -- https://www.useamply.com
# Local sanity (dev server): npm run verify:local-v1
#
# GitHub Actions: secrets AMPLY_PROD_URL + AMPLY_API_KEYS (or put a user key in AMPLY_API_KEYS for POST), workflow "Verify production API".
#
# E2E: npm run amply:verify-bearer && npm run amply:e2e -- https://www.useamply.com
# Latency: npm run probe:synthetic:p95 -- https://www.useamply.com  (needs Bearer in .env)
#   AMPLY_PROBE_ITERATIONS=80 AMPLY_PROBE_ROUTE_MINIMAL=1 npm run probe:synthetic -- https://...
#   AMPLY_PROBE_FAIL_COMPUTE_P95_MS=200 npm run probe:synthetic -- https://...

# --- NextAuth (required for login/dashboard if you use them) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=https://your-production-domain.com

# --- Other ---
# PINECONE_API_KEY=
