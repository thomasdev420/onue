# Copy to .env locally. On Vercel: Settings → Environment Variables (no quotes, no space after =).

# --- Amply v1 routing + Supabase catalog ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_OR_legacy_anon_jwt
SUPABASE_SERVICE_ROLE_KEY=sb_secret_OR_legacy_service_role_jwt

# Optional: comma-separated; if set, POST /api/v1/route requires Authorization: Bearer <key>
# AMPLY_API_KEYS=

# After Vercel deploy, from repo root (optional URL arg):
#   npm run verify:deploy -- https://your-app.vercel.app
#   AMPLY_PROD_URL=https://your-app.vercel.app npm run verify:deploy

# --- NextAuth (required for login/dashboard if you use them) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=https://your-production-domain.com

# --- Other ---
# PINECONE_API_KEY=
